# Server Port Configuration
PORT=5000

# MongoDB Connection URI
MONGO_URI=mongodb://localhost:27017/food-ordering

# Secret Key for JWT signature generation and verification
JWT_SECRET=your_jwt_secret_key_here

# PayHere Merchant Configuration (for checkout / payments flow)
PAYHERE_MERCHANT_ID=your_payhere_merchant_id
PAYHERE_MERCHANT_SECRET=your_payhere_merchant_secret
PAYHERE_SANDBOX=true

# Frontend Client Origin URL (used for CORS policy config)
CLIENT_URL=http://localhost:5173
